# ===========================================
# CONFIGURAÇÃO DO BACKEND - CHAMADOS INTELIGENTES
# ===========================================

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/chamados_inteligentes?schema=public"

# JWT (JSON Web Token)
JWT_SECRET=sua_chave_secreta_jwt_aqui
JWT_EXPIRES_IN=7d

# Google Gemini API
GEMINI_API_KEY=sua_chave_api_gemini_aqui

# CORS
CORS_ORIGIN=*

# Bcrypt
BCRYPT_SALT_ROUNDS=10
